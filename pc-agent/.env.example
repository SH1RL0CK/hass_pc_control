# MQTT connection
MQTT_HOST=192.168.188.64
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password

# MQTT topics (optional, defaults shown)
# TOPIC_LINUX_SET=pc/linux/set
# TOPIC_LINUX_GET=pc/linux/get
# TOPIC_WINDOWS_SET=pc/windows/set
# TOPIC_WINDOWS_GET=pc/windows/get
# TOPIC_INFO=pc/info/get
# TOPIC_AVAILABILITY=pc/info/availability

# Intervals in seconds (optional)
# PC_DATA_INTERVAL=5
# RECONNECT_DELAY=1
