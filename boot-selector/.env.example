# MQTT connection
MQTT_HOST=192.168.188.98
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password

# MQTT topics (optional, defaults shown)
# TOPIC_LINUX_SET=pc/linux/set
# TOPIC_WINDOWS_SET=pc/windows/set

# GRUB entry indices (as shown in grub menu, 0-based)
GRUB_LINUX_ENTRY=0
GRUB_WINDOWS_ENTRY=2

# GRUB timeout in seconds
GRUB_TIMEOUT=3

# Default boot target on startup
# GRUB_DEFAULT_BOOT=linux

# TFTP settings (optional)
# TFTP_DIR=/tftp
# TFTP_HOST=0.0.0.0
# TFTP_PORT=69

# Reconnect delay in seconds (optional)
# RECONNECT_DELAY=5
